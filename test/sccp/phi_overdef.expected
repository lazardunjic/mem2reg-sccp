
define i32 @phi_overdef(i1 %c) {
entry:
  br i1 %c, label %a, label %b

a:                                                ; preds = %entry
  br label %m

b:                                                ; preds = %entry
  br label %m

m:                                                ; preds = %b, %a
  %p = phi i32 [ 1, %a ], [ 2, %b ]
  ret i32 %p
}
